{
  "manifest_version": 3,
  "name": "Proposal Rescue",
  "version": "1.0.0",
  "description": "Never lose a client because you forgot to follow up.",
  "permissions": [
    "storage",
    "alarms",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://api.openai.com/*",
    "https://api.deepseek.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/index.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "icons/*"],
      "matches": ["https://mail.google.com/*"]
    }
  ],
  "side_panel": {
    "default_path": "dashboard.html"
  },
  "options_page": "options.html"
}
